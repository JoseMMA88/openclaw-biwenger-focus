{
  "id": "biwenger-focus",
  "name": "Biwenger Focus",
  "version": "0.1.26",
  "entry": "dist/index.js",
  "description": "Automatic Biwenger auction focus worker with conservative bidding strategy",
  "permissions": {
    "network": {
      "allow": [
        "https://api.telegram.org"
      ]
    },
    "process": {
      "spawn": true
    },
    "filesystem": {
      "read": [
        "/opt/biwenger-mcp",
        "/usr/bin",
        "/usr/local/bin"
      ],
      "write": [
        "/var/lib/openclaw",
        "/tmp"
      ]
    }
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "mcp_command": { "type": "string" },
      "mcp_args": {
        "oneOf": [
          { "type": "array", "items": { "type": "string" } },
          { "type": "string" }
        ]
      },
      "mcp_cwd": { "type": "string" },
      "db_path": { "type": "string" },
      "telegram_bot_token": { "type": "string" },
      "telegram_chat_id": { "type": "string" },
      "tz": { "type": "string" },
      "market_report_enabled": { "type": "boolean" },
      "market_report_tick_sec": { "type": "integer", "minimum": 10 },
      "market_report_opening_only": { "type": "boolean" },
      "market_report_hour": { "type": "integer", "minimum": 0, "maximum": 23 },
      "market_report_minute": { "type": "integer", "minimum": 0, "maximum": 59 },
      "market_report_top_limit": { "type": "integer", "minimum": 1, "maximum": 50 }
    },
    "additionalProperties": false
  }
}
