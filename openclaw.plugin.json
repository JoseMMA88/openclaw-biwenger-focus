{
  "id": "biwenger-focus",
  "name": "Biwenger Focus",
  "version": "0.1.2",
  "entry": "dist/index.js",
  "description": "Automatic Biwenger auction focus worker with conservative bidding strategy",
  "configSchema": {
    "type": "object",
    "properties": {
      "mcp_command": { "type": "string" },
      "mcp_args": {
        "oneOf": [
          { "type": "array", "items": { "type": "string" } },
          { "type": "string" }
        ]
      },
      "mcp_cwd": { "type": "string" },
      "db_path": { "type": "string" },
      "telegram_bot_token": { "type": "string" },
      "telegram_chat_id": { "type": "string" },
      "tz": { "type": "string" }
    },
    "additionalProperties": false
  }
}
