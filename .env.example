# MCP process
MCP_COMMAND=node
MCP_ARGS=/opt/biwenger-mcp/dist/server.js
# Optional. Forces MCP working directory (useful for loading /opt/biwenger-mcp/.env with dotenv/config).
MCP_CWD=/opt/biwenger-mcp
# Optional alternative to load a specific dotenv file in spawned MCP process.
# DOTENV_CONFIG_PATH=/opt/biwenger-mcp/.env

# Biwenger credentials required by biwenger-mcp
# Option A: long-lived token
BIWENGER_TOKEN=
# Option B: email/password login (enables auto re-login on 401/403)
BIWENGER_EMAIL=
BIWENGER_PASSWORD=
BIWENGER_LEAGUE_ID=
BIWENGER_USER_ID=
# Aliases accepted by biwenger-mcp:
# LEAGUE_ID=...
# USER_ID=...

# Optional Biwenger MCP settings
X_LANG=es
X_VERSION=628
TIMEOUT_MS=15000
PLAYER_COMPETITION=la-liga
PLAYER_COMPETITION_CANDIDATES=la-liga

# Data and runtime
FOCUS_DB_PATH=/var/lib/openclaw/biwenger-focus.db
TZ=Europe/Madrid
LOG_LEVEL=info

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional behavior
FOCUS_LOCK_TTL_SEC=30
FOCUS_MISSING_TIMEOUT_SEC=600
FOCUS_TICK_SEC=2
FOCUS_MAX_CONSECUTIVE_ERRORS=15
